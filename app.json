{
  "expo": {
    "name": "Pacewell",
    "slug": "pacewell",
    "scheme": "pacewell",
    "version": "0.10.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#265946"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gonsalves.pacewell",
      "buildNumber": "13",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Pacewell reads your health data to provide personalised recovery insights.",
        "NSHealthUpdateUsageDescription": "Pacewell saves your activity data to help track your recovery."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#265946",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.gonsalves.pacewell",
      "versionCode": 13,
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_EXERCISE",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.health.READ_WEIGHT"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-image-picker",
      "@react-native-community/datetimepicker",
      "expo-health-connect",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "minSdkVersion": 26
          }
        }
      ],
      [
        "react-native-health",
        {
          "isClinicalDataEnabled": false
        }
      ],
      "@kingstinct/react-native-healthkit",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2d6a4f"
        }
      ],
      "expo-font",
      "expo-background-fetch",
      "expo-task-manager"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f2bbc1df-3134-41c4-9ad0-b17b03c4183a"
      }
    }
  }
}
